{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the BookMind application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Book": {
      "title": "Book",
      "description": "A book in the library.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "coverUrl": { "type": "string" },
        "description": { "type": "string" },
        "topics": { "type": "array", "items": { "type": "string" } },
        "available": { "type": "boolean" },
        "aiSummary": { "type": "string" },
        "quotes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "author", "available", "createdAt"]
    },
    "BorrowRecord": {
      "title": "BorrowRecord",
      "description": "A record of a user borrowing a book.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "bookId": { "type": "string" },
        "borrowedAt": { "type": "string", "format": "date-time" },
        "dueDate": { "type": "string", "format": "date-time" },
        "returnedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "returned", "overdue"] }
      },
      "required": ["userId", "bookId", "borrowedAt", "dueDate", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles."
    },
    "/books/{bookId}": {
      "schema": { "$ref": "#/entities/Book" },
      "description": "Library books."
    },
    "/borrowRecords/{recordId}": {
      "schema": { "$ref": "#/entities/BorrowRecord" },
      "description": "Records of borrowed books."
    }
  }
}
